# === AZURE DOCUMENT INTELLIGENCE ===
# Portal → tu recurso Document Intelligence → Keys and Endpoint
DOCUMENTINTELLIGENCE_ENDPOINT=
DOCUMENTINTELLIGENCE_API_KEY=

# === AZURE AI SEARCH ===
# Portal → tu recurso AI Search → Keys → Admin key
AZURE_SEARCH_ENDPOINT=https://TU_SEARCH.search.windows.net
AZURE_SEARCH_KEY=TU_ADMIN_KEY_AQUI
AZURE_SEARCH_INDEX=documentos-empresariales

# === AZURE BLOB STORAGE ===
# Portal → tu Storage Account → Access keys → Connection string
AZURE_STORAGE_CONNECTION=DefaultEndpointsProtocol=https;AccountName=TU_CUENTA;AccountKey=TU_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=documentos

# === OPENAI (tu API directa, no Azure OpenAI) ===
OPENAI_API_KEY=sk-TU_KEY_AQUI
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
